#!/bin/bash
# pre-commit Hook - Gate 流程保障检查
# V2.3 Gate 流程保障机制
#
# 检查受保护文档目录变更时的 Gate 签字状态
# 受保护目录: docs/prd/, docs/tech/, docs/qa/

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Gate 定义
PROTECTED_DIRS="docs/prd docs/tech docs/qa"

echo ""
echo "=========================================="
echo "Gate 流程保障检查 (pre-commit hook)"
echo "=========================================="

# 检查是否有受保护目录的文件被修改
CHANGED_PROTECTED_FILES=$(git diff --cached --name-only | grep -E "^docs/(prd|tech|qa)/" || true)

if [ -z "$CHANGED_PROTECTED_FILES" ]; then
    echo "[OK] 没有受保护文档目录的变更，跳过 Gate 检查"
    exit 0
fi

echo ""
echo "[检查] 发现受保护文档变更:"
echo "$CHANGED_PROTECTED_FILES" | while read -r file; do
    echo "  - $file"
done

echo ""
echo "=========================================="
echo "Gate 签字状态检查"
echo "=========================================="

# 按文件类型检查 Gate
ERRORS=0

# 检查 PRD Gate 1
PRD_FILES=$(echo "$CHANGED_PROTECTED_FILES" | grep "^docs/prd/" || true)
if [ -n "$PRD_FILES" ]; then
    echo ""
    echo "[PRD Gate 1] 检查 PRD 文档签字状态..."
    for prd_file in $PRD_FILES; do
        echo "  检查文件: $prd_file"

        # 检查是否存在 Gate 块
        if grep -q "Gate 1\|PRD Gate" "$prd_file" 2>/dev/null; then
            # 检查签字
            PM_SIG=$(grep -i "PM" "$prd_file" 2>/dev/null | grep -i "sign" | head -1 || true)
            CTO_SIG=$(grep -i "CTO" "$prd_file" 2>/dev/null | head -1 || true)
            CSO_SIG=$(grep -i "CSO\|CRO" "$prd_file" 2>/dev/null | head -1 || true)

            if [ -n "$PM_SIG" ] && [ -n "$CTO_SIG" ]; then
                echo -e "  ${GREEN}[OK]${NC} PRD Gate 1: PM + CTO 签字存在"
            else
                echo -e "  ${RED}[ERROR]${NC} PRD Gate 1: 缺少必需的签字 (需要 PM + CTO + CSO/CRO)"
                ERRORS=$((ERRORS + 1))
            fi
        else
            echo -e "  ${RED}[ERROR]${NC} PRD 文件缺少 Gate 块"
            echo "  提示: PRD 文档需要包含 Gate 块，标明 Gate 1 和各方签字状态"
            ERRORS=$((ERRORS + 1))
        fi
    done
fi

# 检查 Tech Gate 2
TECH_FILES=$(echo "$CHANGED_PROTECTED_FILES" | grep "^docs/tech/" || true)
if [ -n "$TECH_FILES" ]; then
    echo ""
    echo "[Tech Gate 2] 检查 Tech 文档签字状态..."
    for tech_file in $TECH_FILES; do
        echo "  检查文件: $tech_file"

        if grep -q "Gate 2\|Tech Gate" "$tech_file" 2>/dev/null; then
            PM_SIG=$(grep -i "PM" "$tech_file" 2>/dev/null | grep -i "sign" | head -1 || true)
            CRO_SIG=$(grep -i "CRO" "$tech_file" 2>/dev/null | head -1 || true)
            QA_SIG=$(grep -i "QA" "$tech_file" 2>/dev/null | grep -i "sign\|review" | head -1 || true)

            if [ -n "$PM_SIG" ] && [ -n "$CRO_SIG" ] && [ -n "$QA_SIG" ]; then
                echo -e "  ${GREEN}[OK]${NC} Tech Gate 2: PM + CRO + QA 签字存在"
            else
                echo -e "  ${RED}[ERROR]${NC} Tech Gate 2: 缺少必需的签字 (需要 PM + CRO + QA)"
                ERRORS=$((ERRORS + 1))
            fi
        else
            echo -e "  ${RED}[ERROR]${NC} Tech 文件缺少 Gate 块"
            echo "  提示: Tech 文档需要包含 Gate 块，标明 Gate 2 和各方签字状态"
            ERRORS=$((ERRORS + 1))
        fi
    done
fi

# 检查 QA Case Design Gate
QA_FILES=$(echo "$CHANGED_PROTECTED_FILES" | grep "^docs/qa/" || true)
if [ -n "$QA_FILES" ]; then
    echo ""
    echo "[QA Case Design Gate] 检查 QA 文档签字状态..."
    for qa_file in $QA_FILES; do
        echo "  检查文件: $qa_file"

        if grep -q "Gate\|Sign" "$qa_file" 2>/dev/null; then
            PM_SIG=$(grep -i "PM" "$qa_file" 2>/dev/null | grep -i "sign" | head -1 || true)
            CTO_SIG=$(grep -i "CTO" "$qa_file" 2>/dev/null | head -1 || true)
            ENG_SIG=$(grep -i "Engineer\|ENG" "$qa_file" 2>/dev/null | grep -i "sign\|review" | head -1 || true)

            if [ -n "$PM_SIG" ] && [ -n "$CTO_SIG" ] && [ -n "$ENG_SIG" ]; then
                echo -e "  ${GREEN}[OK]${NC} QA Case Design Gate: PM + CTO + Engineer 签字存在"
            else
                echo -e "  ${YELLOW}[WARNING]${NC} QA Case Design Gate: 部分签字可能缺失 (需要 PM + CTO + Engineer)"
            fi
        fi
    done
fi

echo ""
echo "=========================================="
echo "Gate 检查结果"
echo "=========================================="

if [ $ERRORS -gt 0 ]; then
    echo ""
    echo -e "${RED}[Gate Check] FAILED${NC}"
    echo ""
    echo "问题: 文档 PR 提交时，关联的 Gate 尚未全部签字"
    echo ""
    echo "要求:"
    echo "  □ PRD Gate 1 (PM + CTO + CSO/CRO)"
    echo "  □ Tech Gate 2 (PM + CRO + QA)"
    echo "  □ QA Case Design Gate (PM + CTO + Engineer)"
    echo ""
    echo "解决方案:"
    echo "  1. 完成所有 Gate 签字后再提交 PR"
    echo "  2. 参考: prompts/004_delivery_gates.md"
    echo "  3. 参考: prompts/019_dual_stage_pr_and_three_layer_safeguard.md"
    echo ""
    exit 1
else
    echo ""
    echo -e "${GREEN}[Gate Check] PASSED${NC}"
    echo "所有 Gate 签字状态已确认"
    exit 0
fi
